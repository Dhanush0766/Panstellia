# Copy to functions/.env and do NOT commit real secrets.

# Razorpay server-side credentials (NEVER expose to frontend)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated allowed Vercel/custom domains.
CORS_ORIGINS=https://panstellia.vercel.app,https://panstellia.com,https://www.panstellia.com

